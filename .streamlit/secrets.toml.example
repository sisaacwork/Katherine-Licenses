# Copy this file to secrets.toml and fill in your values.
# Run setup_password.py to generate the password hash.
# Run setup_oauth.py to generate the Google OAuth refresh token.

[auth]
password_hash = "run_setup_password_py_to_generate_this"

# ── Google OAuth 2.0 (replaces service account) ───────────────────────────────
# Service accounts cannot upload to personal Google Drive (no storage quota).
# OAuth authenticates as the real user so files go into their own Drive.
#
# How to get these values:
#   1. console.cloud.google.com → APIs & Services → Credentials
#   2. Create OAuth 2.0 Client ID → Application type: Desktop app
#   3. Run:  python setup_oauth.py
#   4. Sign in as Katie in the browser that opens
#   5. Paste the three printed values below

[google_oauth]
client_id     = "your-client-id.apps.googleusercontent.com"
client_secret = "your-client-secret"
refresh_token = "your-refresh-token"

# ── Google Drive ───────────────────────────────────────────────────────────────
# Create a folder in Katie's Google Drive and paste its ID here.
# The folder ID is the last segment of the folder's URL:
#   https://drive.google.com/drive/folders/THIS_PART_IS_THE_ID

[drive]
root_folder_id = "your-root-google-drive-folder-id"
